# ==========================================
# CINEIQ — Environment Variables Template
# ==========================================

# ─── API Keys (REPLACE THESE) ───
# Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# External Data & LLM
TMDB_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Application Settings ───
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000", "https://*.vercel.app"]
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# ─── Database & Storage ───
# Upstash Redis
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
